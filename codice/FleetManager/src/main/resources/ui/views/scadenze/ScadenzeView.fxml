<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
	xmlns:fx="http://javafx.com/fxml"
	fx:controller="it.fleetmanager.ui.scadenze.ScadenzeController"
	style="-fx-background-color: #e9f0f7;">

	<!-- HEADER -->
	<top>
		<VBox alignment="CENTER" spacing="5"
			style="-fx-padding: 25 0 15 0;">
			<Label text="Gestione Scadenze"
				style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />

			<Label fx:id="lblInfoUtente" text="Caricamento..."
				style="-fx-font-size: 15; -fx-text-fill:#4a76a8;" />
		</VBox>
	</top>

	<!-- CONTENUTO -->
	<center>
		<VBox alignment="CENTER" spacing="20">

			<VBox alignment="CENTER" prefWidth="1100" spacing="15"
				style="-fx-background-color: white;
                         -fx-background-radius: 15;
                         -fx-padding: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0.2, 0, 4);">

				<TableView fx:id="tableScadenze" prefHeight="450"
					prefWidth="1050">
					<columns>
						<TableColumn fx:id="colId" text="ID" prefWidth="70" />
						<TableColumn fx:id="colTarga" text="Targa"
							prefWidth="120" />
						<TableColumn fx:id="colTipo" text="Tipo Scadenza"
							prefWidth="200" />
						<TableColumn fx:id="colData" text="Data"
							prefWidth="150" />
						<TableColumn fx:id="colNotificata" text="Notificata"
							prefWidth="120" />
					</columns>
				</TableView>

			</VBox>

			<!-- BOTTONI -->
			<HBox alignment="CENTER" spacing="20">

				<Button text="Aggiungi" onAction="#onAggiungi"
					prefWidth="180"
					style="-fx-background-radius: 10; -fx-font-size: 16; -fx-font-weight: bold;
                               -fx-text-fill: white; -fx-padding: 10 20;
                               -fx-background-color: linear-gradient(to right,#4a76a8,#2f4773);" />

				<Button text="Modifica" onAction="#onModifica"
					prefWidth="180"
					style="-fx-background-radius: 10; -fx-font-size: 16; -fx-font-weight: bold;
                               -fx-text-fill: white; -fx-padding: 10 20;
                               -fx-background-color: linear-gradient(to right,#5e8bbf,#466c9c);" />

				<Button text="Elimina" onAction="#onElimina" prefWidth="180"
					style="-fx-background-radius: 10; -fx-font-size: 16; -fx-font-weight: bold;
                               -fx-text-fill: white; -fx-padding: 10 20;
                               -fx-background-color: linear-gradient(to right,#e45757,#b33030);" />

				<Button text="Torna alla Dashboard" onAction="#onBack"
					prefWidth="220"
					style="-fx-background-radius: 10; -fx-font-size: 16; -fx-font-weight: bold;
                               -fx-text-fill: white; -fx-padding: 10 20;
                               -fx-background-color: linear-gradient(to right,#b2c7db,#92aac4);" />

			</HBox>

		</VBox>
	</center>

</BorderPane>
