<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.fleetmanager.ui.manutenzioni.NuovaManutenzioneController"
            prefWidth="900" prefHeight="600"
            style="-fx-background-color: #e9f0f7;">

    <center>
        <VBox alignment="CENTER" spacing="20">

            <!-- TITOLO -->
            <Label text="Nuova Manutenzione"
                   style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />

            <!-- CARD -->
            <VBox spacing="15" alignment="CENTER_LEFT"
                  prefWidth="600"
                  style="
                     -fx-background-color: white;
                     -fx-background-radius: 15;
                     -fx-padding: 25;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0.2, 0, 4);
                  ">

                <!-- TARGA -->
                <Label text="Targa veicolo:" style="-fx-font-size: 16; -fx-text-fill:#2f4773;" />
                <ComboBox fx:id="cbTarga" prefWidth="300"/>

                <!-- TIPO -->
                <Label text="Tipo manutenzione:" style="-fx-font-size: 16; -fx-text-fill:#2f4773;" />
                <ComboBox fx:id="cbTipo" prefWidth="300"/>

                <!-- DATA -->
                <Label text="Data:" style="-fx-font-size: 16; -fx-text-fill:#2f4773;" />
                <DatePicker fx:id="dpData" prefWidth="200"/>

                <!-- ORARI -->
                <HBox spacing="30">
                    <VBox spacing="5">
                        <Label text="Ora inizio (HH:mm)" style="-fx-font-size: 16; -fx-text-fill:#2f4773;" />
                        <TextField fx:id="txtOraInizio" promptText="09:00" prefWidth="120"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Ora fine (HH:mm)" style="-fx-font-size: 16; -fx-text-fill:#2f4773;" />
                        <TextField fx:id="txtOraFine" promptText="11:00" prefWidth="120"/>
                    </VBox>
                </HBox>

                <!-- DESCRIZIONE -->
                <Label text="Descrizione:"
                       style="-fx-font-size: 16; -fx-text-fill:#2f4773;" />
                <TextArea fx:id="txtDescrizione"
                          prefWidth="500"
                          prefHeight="120"
                          wrapText="true"/>

            </VBox>

            <!-- BOTTONI -->
            <HBox alignment="CENTER" spacing="20">
                <Button text="Conferma"
                        onAction="#onConferma"
                        prefWidth="180"
                        style="-fx-background-radius: 10;
                               -fx-font-size: 16;
                               -fx-font-weight: bold;
                               -fx-text-fill: white;
                               -fx-background-color: linear-gradient(to right,#4a76a8,#2f4773);" />

                <Button text="Annulla"
                        onAction="#onAnnulla"
                        prefWidth="180"
                        style="-fx-background-radius: 10;
                               -fx-font-size: 16;
                               -fx-font-weight: bold;
                               -fx-text-fill: white;
                               -fx-background-color: linear-gradient(to right,#8fb3d6,#6b8eb9);" />
            </HBox>

        </VBox>
    </center>

</BorderPane>
