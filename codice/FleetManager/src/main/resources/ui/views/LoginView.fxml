<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
	xmlns:fx="http://javafx.com/fxml"
	fx:controller="it.fleetmanager.ui.LoginController"
	style="-fx-background-color: #f5f6fa;">

	<center>
		<VBox spacing="20" alignment="CENTER" prefWidth="400"
			prefHeight="450" BorderPane.alignment="CENTER"
			style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 40;">

			<effect>
				<DropShadow radius="8" color="#AAAAAA" />
			</effect>

			<!-- TITOLO -->
			<Label text="FleetManager Login" style="-fx-text-fill:#2f3640;">
				<font>
					<Font size="26" />
				</font>
			</Label>

			<!-- Email -->
			<VBox spacing="5" alignment="CENTER_LEFT">
				<Label text="Email:" style="-fx-text-fill:#353b48;">
					<font>
						<Font size="14" />
					</font>
				</Label>
				<TextField fx:id="emailField" promptText="Inserisci email"
					style="-fx-background-radius: 6; -fx-padding:8;" />
			</VBox>

			<!-- Password -->
			<VBox spacing="5" alignment="CENTER_LEFT">
				<Label text="Password:" style="-fx-text-fill:#353b48;">
					<font>
						<Font size="14" />
					</font>
				</Label>
				<PasswordField fx:id="passwordField"
					promptText="Inserisci password"
					style="-fx-background-radius: 6; -fx-padding:8;" />
			</VBox>

			<!-- Messaggio errore -->
			<Label fx:id="errorLabel" text=""
				style="-fx-text-fill: red; -fx-font-size: 13;" />

			<!-- Pulsante LOGIN -->
			<Button text="Accedi" onAction="#onLoginClicked"
				style="
                        -fx-background-color: #487eb0;
                        -fx-text-fill: white;
                        -fx-background-radius: 8;
                        -fx-font-size: 16;
                        -fx-padding: 10 20 10 20;"
				prefWidth="200" />

		</VBox>
	</center>

</BorderPane>
