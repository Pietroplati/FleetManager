<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
	xmlns:fx="http://javafx.com/fxml"
	fx:controller="it.fleetmanager.ui.LoginController" prefWidth="1280"
	prefHeight="720" style="-fx-background-color: #e9f0f7;">


	<!-- ========================================================= -->
	<!-- HERO PANEL SINISTRO -->
	<!-- ========================================================= -->
	<left>
		<StackPane prefWidth="480"
			style="
                       -fx-background-color: linear-gradient(to bottom,
                           #c7d7e6, #b4c8db, #a7bfd7);
                   ">

			<VBox alignment="CENTER_LEFT" spacing="15"
				style="-fx-padding: 80 50;">

				<Label text="🚗"
					style="-fx-font-size: 56; -fx-text-fill: #2f4773;" />

				<Label text="FleetManager"
					style="-fx-font-size: 38;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2f4773;" />

				<Label text="Gestione flotta facile e veloce"
					style="-fx-font-size: 18;
                              -fx-text-fill: #4a76a8;" />

			</VBox>

		</StackPane>
	</left>


	<!-- ========================================================= -->
	<!-- LOGIN CARD -->
	<!-- ========================================================= -->
	<center>
		<VBox alignment="CENTER" spacing="25">

			<VBox alignment="CENTER" spacing="20"
				style="
                      -fx-background-color: white;
                      -fx-background-radius: 18;
                      -fx-padding: 40 35;
                      -fx-effect: dropshadow(gaussian,
                                             rgba(0,0,0,0.15),
                                             18, 0.25, 0, 4);
                  "
				maxWidth="380">

				<Label text="Accedi"
					style="-fx-font-size: 26;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2f4773;" />

				<!-- EMAIL -->
				<VBox alignment="CENTER_LEFT" spacing="6">
					<Label text="Email"
						style="-fx-font-size: 14; -fx-text-fill:#2f4773;" />

					<TextField fx:id="emailField"
						promptText="Inserisci email"
						style="
                                   -fx-background-color: #f5f8fb;
                                   -fx-border-color: #c7d7e6;
                                   -fx-border-radius: 8;
                                   -fx-background-radius: 8;
                                   -fx-padding: 10;
                                   -fx-text-fill: #2f4773;
                                   -fx-prompt-text-fill: #8fb3d6;
                               " />
				</VBox>


				<!-- PASSWORD -->
				<VBox alignment="CENTER_LEFT" spacing="6">
					<Label text="Password"
						style="-fx-font-size: 14; -fx-text-fill:#2f4773;" />

					<PasswordField fx:id="passwordField"
						promptText="Inserisci password"
						style="
                                       -fx-background-color: #f5f8fb;
                                       -fx-border-color: #c7d7e6;
                                       -fx-border-radius: 8;
                                       -fx-background-radius: 8;
                                       -fx-padding: 10;
                                       -fx-text-fill: #2f4773;
                                       -fx-prompt-text-fill: #8fb3d6;
                                   " />
				</VBox>


				<!-- ERRORE -->
				<Label fx:id="errorLabel"
					style="-fx-font-size: 14;
                              -fx-text-fill:#cc4c4c;
                              -fx-font-weight:bold;" />


				<!-- LOGIN BUTTON -->
				<Button text="Accedi" onAction="#onLoginClicked"
					prefWidth="240"
					style="
                            -fx-background-radius: 10;
                            -fx-font-size: 17;
                            -fx-padding: 10;
                            -fx-font-weight: bold;
                            -fx-text-fill: white;
                            -fx-background-color: linear-gradient(to right,
                                #4a76a8, #2f4773);
                        " />

			</VBox>

		</VBox>
	</center>

</BorderPane>
