<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
	xmlns:fx="http://javafx.com/fxml"
	fx:controller="it.fleetmanager.ui.dashboards.DriverDashboardController"
	style="-fx-background-color: #e9f0f7;">

	<center>
		<AnchorPane>

			<children>

				<!-- ===================== CONTENUTO CENTRALE ===================== -->
				<VBox spacing="40" alignment="CENTER" AnchorPane.topAnchor="0"
					AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
					AnchorPane.rightAnchor="0" VBox.vgrow="ALWAYS">

					<!-- ===== HEADER ===== -->
					<VBox alignment="CENTER" spacing="10">

						<Circle radius="45" fill="#8fb3d6">
							<effect>
								<DropShadow radius="20" color="rgba(0,0,0,0.20)" />
							</effect>
						</Circle>

						<Label text="Area Driver"
							style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />

						<Label text="Benvenuto nella tua dashboard"
							style="-fx-font-size: 15; -fx-text-fill:#4a76a8;" />

					</VBox>


					<!-- ===== WIDGETS ===== -->
					<HBox alignment="CENTER" spacing="25">

						<!-- Widget 1 -->
						<VBox alignment="CENTER" spacing="8" maxWidth="220"
							maxHeight="130"
							style="-fx-background-color: white;
                                     -fx-background-radius: 15;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0.2, 0, 4);">

							<Label text="Prenotazioni attive"
								style="-fx-font-size: 15; -fx-text-fill:#2f4773;" />

							<Label fx:id="lblPrenotazioniAttive" text="0"
								style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />

						</VBox>

						<!-- Widget 2 -->
						<VBox alignment="CENTER" spacing="8" maxWidth="220"
							maxHeight="130"
							style="-fx-background-color: white;
                                     -fx-background-radius: 15;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0.2, 0, 4);">

							<Label text="Prossima prenotazione"
								style="-fx-font-size: 15; -fx-text-fill:#2f4773;" />

							<Label fx:id="lblProssimaPrenotazione" text="Nessuna"
								style="-fx-font-size: 18; -fx-text-fill:#2f4773;" />

						</VBox>

						<!-- Widget 3 -->
						<VBox alignment="CENTER" spacing="8" maxWidth="220"
							maxHeight="130"
							style="-fx-background-color: white;
                                     -fx-background-radius: 15;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0.2, 0, 4);">

							<Label text="Veicolo assegnato"
								style="-fx-font-size: 15; -fx-text-fill:#2f4773;" />

							<Label fx:id="lblVeicoloAssegnato" text="Nessuno"
								style="-fx-font-size: 18; -fx-text-fill:#2f4773;" />

						</VBox>

					</HBox>


					<!-- ===== INFO UTENTE ===== -->
					<VBox alignment="CENTER_LEFT" spacing="10" maxWidth="700"
						style="-fx-background-color: white;
                                 -fx-background-radius: 15;
                                 -fx-padding: 25 30;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0.2, 0, 4);">

						<Label text="Informazioni personali"
							style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />

						<VBox spacing="6">
							<Label fx:id="lblNome"
								style="-fx-font-size: 14; -fx-text-fill:#2f4773;" />
							<Label fx:id="lblEmail"
								style="-fx-font-size: 14; -fx-text-fill:#2f4773;" />
							<Label fx:id="lblPatente"
								style="-fx-font-size: 14; -fx-text-fill:#2f4773;" />
						</VBox>

					</VBox>


					<!-- ===== BOTTONI ===== -->
					<HBox alignment="CENTER" spacing="20">

						<Button text="Le mie prenotazioni"
							onAction="#onApriPrenotazioni" prefWidth="220"
							style="-fx-background-radius: 10;
                                       -fx-font-size: 16;
                                       -fx-font-weight: bold;
                                       -fx-text-fill: white;
                                       -fx-padding: 10 20;
                                       -fx-background-color: linear-gradient(to right,#4a76a8,#2f4773);" />

						<Button text="Prenota un veicolo"
							onAction="#onNuovaPrenotazione" prefWidth="220"
							style="-fx-background-radius: 10;
                                       -fx-font-size: 16;
                                       -fx-font-weight: bold;
                                       -fx-text-fill: white;
                                       -fx-padding: 10 20;
                                       -fx-background-color: linear-gradient(to right,#5e8bbf,#466c9c);" />

						<Button text="Segnalazione straordinaria"
							onAction="#onSegnalazioneStraordinaria" prefWidth="220"
							style="-fx-background-radius: 10;
                                       -fx-font-size: 16;
                                       -fx-font-weight: bold;
                                       -fx-text-fill: white;
                                       -fx-padding: 10 20;
                                       -fx-background-color: linear-gradient(to right,#e45757,#b33030);" />

						<Button text="Logout" onAction="#onLogout" prefWidth="220"
							style="-fx-background-radius: 10;
                                       -fx-font-size: 16;
                                       -fx-font-weight: bold;
                                       -fx-text-fill: white;
                                       -fx-padding: 10 20;
                                       -fx-background-color: linear-gradient(to right,#8fb3d6,#6b8eb9);" />

					</HBox>

				</VBox>

				<!-- ========== BOTTONE NOTIFICHE + BADGE (SPOSTATO SOPRA LA VBOX) ========== -->
				<AnchorPane AnchorPane.topAnchor="20"
					AnchorPane.rightAnchor="20">

					<Button fx:id="btnNotifiche" onAction="#onApriNotifiche"
						prefWidth="85" prefHeight="40"
						style="
                                -fx-background-radius: 12;
                                -fx-background-color: white;
                                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 8, 0.15, 0, 2);
                                -fx-padding: 5;
                            ">

						<graphic>
							<ImageView fitWidth="22" fitHeight="22">
								<image>
									<Image
										url="https://img.icons8.com/ios-filled/50/000000/message-group.png" />
								</image>
							</ImageView>
						</graphic>

					</Button>

					<!-- 🔴 BADGE NOTIFICHE -->
					<Circle fx:id="badgeNotifiche" radius="6" fill="red"
						visible="false" AnchorPane.rightAnchor="4"
						AnchorPane.topAnchor="4" />

				</AnchorPane>

			</children>

		</AnchorPane>
	</center>

</BorderPane>
