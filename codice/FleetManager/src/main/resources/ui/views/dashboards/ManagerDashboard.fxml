<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx"
	xmlns:fx="http://javafx.com/fxml"
	fx:controller="it.fleetmanager.ui.dashboards.ManagerDashboardController"
	style="-fx-background-color: #e9f0f7;">

	<center>
		<AnchorPane>

			<children>

				<!-- ===================== DASHBOARD CENTRALE ===================== -->
				<VBox alignment="CENTER" spacing="40" AnchorPane.topAnchor="0"
					AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
					AnchorPane.rightAnchor="0">

					<!-- HEADER -->
					<VBox alignment="CENTER" spacing="10">

						<Circle radius="45" fill="#8fb3d6">
							<effect>
								<DropShadow radius="20" color="rgba(0,0,0,0.20)" />
							</effect>
						</Circle>

						<Label text="Dashboard Manager"
							style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />

						<Label text="Pannello di controllo della flotta"
							style="-fx-font-size: 15; -fx-text-fill:#4a76a8;" />

					</VBox>

					<!-- WIDGET CONTAINER -->
					<HBox alignment="CENTER" spacing="25">

						<!-- ===== VEICOLI ===== -->
						<VBox alignment="CENTER" spacing="8" prefWidth="220"
							prefHeight="130"
							style="-fx-background-color: white;
                                     -fx-background-radius: 15;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0.2, 0, 4);">

							<Label text="Veicoli totali"
								style="-fx-font-size: 15; -fx-text-fill:#2f4773;" />
							<Label fx:id="lblTotVeicoli" text="0"
								style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />
						</VBox>

						<!-- ===== PRENOTAZIONI ===== -->
						<VBox alignment="CENTER" spacing="8" prefWidth="220"
							prefHeight="130"
							style="-fx-background-color: white;
                                     -fx-background-radius: 15;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0.2, 0, 4);">

							<Label text="Prenotazioni attive"
								style="-fx-font-size: 15; -fx-text-fill:#2f4773;" />
							<Label fx:id="lblPrenotazioniAttive" text="0"
								style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />
						</VBox>

						<!-- ===== MANUTENZIONI ===== -->
						<VBox alignment="CENTER" spacing="8" prefWidth="220"
							prefHeight="130"
							style="-fx-background-color: white;
                                     -fx-background-radius: 15;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0.2, 0, 4);">

							<Label text="Manutenzioni aperte"
								style="-fx-font-size: 15; -fx-text-fill:#2f4773;" />
							<Label fx:id="lblManutenzioni" text="0"
								style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />
						</VBox>

					</HBox>

					<!-- ===================== BUTTONS ===================== -->
					<HBox alignment="CENTER" spacing="20">

						<!-- Gestisci Veicoli -->
						<Button text="Gestisci Veicoli"
							onAction="#onGestisciVeicoli" prefWidth="230"
							style="-fx-background-radius: 10; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-text-fill: white; -fx-padding: 10 20;
                                       -fx-background-color: linear-gradient(to right,#4a76a8,#2f4773);" />

						<Button text="Gestisci Utenti" onAction="#onGestisciUtenti"
							prefWidth="230"
							style="-fx-background-radius: 10;
             				   -fx-font-size: 16;
				               -fx-font-weight: bold;
				               -fx-text-fill: white;
				               -fx-padding: 10 20;
				               -fx-background-color: linear-gradient(to right,#6f9bcf,#4a76a8);" />

						<!-- Gestisci Prenotazioni -->
						<Button text="Gestisci Prenotazioni"
							onAction="#onGestisciPrenotazioni" prefWidth="230"
							style="-fx-background-radius: 10; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-text-fill: white; -fx-padding: 10 20;
                                       -fx-background-color: linear-gradient(to right,#5e8bbf,#466c9c);" />

						<!-- Gestisci Manutenzioni -->
						<Button text="Gestisci Manutenzioni"
							onAction="#onGestisciManutenzioni" prefWidth="230"
							style="-fx-background-radius: 10; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-text-fill: white; -fx-padding: 10 20;
                                       -fx-background-color: linear-gradient(to right,#8fb3d6,#6b8eb9);" />

						<!-- 🔥 NUOVO: Gestisci Scadenze -->
						<Button text="Gestisci Scadenze"
							onAction="#onGestisciScadenze" prefWidth="230"
							style="
            -fx-background-radius: 10;
            -fx-font-size: 16;
            -fx-font-weight: bold;
            -fx-text-fill: white;
            -fx-padding: 10 20;
            -fx-background-color: linear-gradient(to right,#7ba3cc,#577fa6);
        " />

						<!-- Logout -->
						<Button text="Logout" onAction="#onLogout" prefWidth="230"
							style="-fx-background-radius: 10; -fx-font-size: 16; -fx-font-weight: bold;
                                       -fx-text-fill: white; -fx-padding: 10 20;
                                       -fx-background-color: linear-gradient(to right,#b2c7db,#92aac4);" />

					</HBox>

				</VBox>

				<!-- ===================== BOTTONE NOTIFICHE + BADGE ===================== -->
				<AnchorPane AnchorPane.topAnchor="20"
					AnchorPane.rightAnchor="20">

					<Button fx:id="btnNotifiche" onAction="#onApriNotifiche"
						prefWidth="85" prefHeight="40"
						style="-fx-background-radius: 12; -fx-background-color: white;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 8, 0.15, 0, 2);">

						<graphic>
							<ImageView fitWidth="22" fitHeight="22">
								<image>
									<Image
										url="https://img.icons8.com/ios-filled/50/000000/message-group.png" />
								</image>
							</ImageView>
						</graphic>

					</Button>

					<Circle fx:id="badgeNotifiche" radius="6" fill="red"
						visible="false" AnchorPane.rightAnchor="4"
						AnchorPane.topAnchor="4" />

				</AnchorPane>

			</children>

		</AnchorPane>
	</center>

</BorderPane>
