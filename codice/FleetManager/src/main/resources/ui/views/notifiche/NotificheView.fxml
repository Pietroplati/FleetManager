<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
	xmlns:fx="http://javafx.com/fxml"
	fx:controller="it.fleetmanager.ui.notifiche.NotificheController"
	style="-fx-background-color: #e9f0f7;">

	<!-- =================== HEADER =================== -->
	<top>
		<VBox alignment="CENTER" spacing="5"
			style="-fx-padding: 25 0 15 0;">

			<Label text="Notifiche"
				style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill:#2f4773;" />

			<Label fx:id="lblDescrizioneUtente" text="Caricamento..."
				style="-fx-font-size: 15; -fx-text-fill:#4a76a8;" />

			<ProgressIndicator fx:id="loadingIndicator"
				visible="false" prefWidth="40" prefHeight="40" />
		</VBox>
	</top>

	<!-- =================== CONTENUTO =================== -->
	<center>
		<VBox alignment="CENTER" spacing="20">

			<VBox alignment="CENTER" prefWidth="1100" spacing="15"
				style="
                      -fx-background-color: white;
                      -fx-background-radius: 15;
                      -fx-padding: 20;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 15, 0.2, 0, 4);
                  ">

				<TableView fx:id="tableNotifiche" prefHeight="450"
					prefWidth="1050">

					<columns>
						<TableColumn fx:id="colId" text="ID" prefWidth="70" />
						<TableColumn fx:id="colTipo" text="Tipo"
							prefWidth="140" />
						<TableColumn fx:id="colMessaggio" text="Messaggio"
							prefWidth="420" />
						<TableColumn fx:id="colData" text="Data"
							prefWidth="200" />
						<TableColumn fx:id="colLetta" text="Letta"
							prefWidth="120" />
					</columns>

				</TableView>

			</VBox>

			<!-- =================== BOTTONI =================== -->
			<HBox alignment="CENTER" spacing="20">

				<!-- Refresh -->
				<Button text="↻" fx:id="btnRefresh" onAction="#onRefresh"
					prefWidth="45" prefHeight="45"
					style="
                            -fx-background-radius: 50;
                            -fx-font-size: 22;
                            -fx-font-weight: bold;
                            -fx-text-fill: white;
                            -fx-background-color: linear-gradient(to right,#4e9ac7,#35739c);
                        " />

				<!-- Segna tutte come lette -->
				<Button text="Segna tutte come lette" fx:id="btnSegnaTutte"
					onAction="#onSegnaTutteComeLette" prefWidth="220"
					style="
                           -fx-background-radius: 10;
                           -fx-font-size: 16;
                           -fx-font-weight: bold;
                           -fx-text-fill: white;
                           -fx-background-color: linear-gradient(to right,#4a76a8,#2f4773);
                        " />

				<!-- Torna alla dashboard -->
				<Button text="Torna alla Dashboard" onAction="#onBack"
					prefWidth="220"
					style="
                           -fx-background-radius: 10;
                           -fx-font-size: 16;
                           -fx-font-weight: bold;
                           -fx-text-fill: white;
                           -fx-background-color: linear-gradient(to right,#b2c7db,#92aac4);
                        " />

			</HBox>

		</VBox>
	</center>

</BorderPane>
